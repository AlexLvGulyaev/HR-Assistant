# HR Assistant Environment Variables Example
# Copy this file to .env and update values for your deployment

# ============================================================
# PostgreSQL Configuration
# ============================================================

POSTGRES_DB=hr_assistant
POSTGRES_USER=hr_user
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE

# ============================================================
# n8n Configuration
# ============================================================

N8N_HOST=your-domain.com
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://your-domain.com/
N8N_EDITOR_BASE_URL=https://your-domain.com/
N8N_ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE
GENERIC_TIMEZONE=Europe/Berlin

# ============================================================
# Traefik (SSL) Configuration
# ============================================================

TRAEFIK_EMAIL=your-email@example.com

# ============================================================
# IMPORTANT: Credentials Configuration
# ============================================================
#
# Telegram Bot Token and OpenAI API Key are NOT configured via
# environment variables. They must be configured in n8n credential store.
#
# See DEPLOYMENT_GUIDE.md for setup instructions:
#
# 1. n8n → Settings → Credentials
# 2. Create "Postgres account" credential
# 3. Create "OpenAI API" credential (Header Auth)
# 4. Create "Telegram API" credential
#
# For HR Delivery Worker, bot token is stored in bot_credentials table.
# See DEPLOYMENT_GUIDE.md for initial setup.
#
# ============================================================