    {
      "parameters": {
        "jsCode": "const input = $input.first()?.json || {};\n\nconst chatId = String(\n  input.chat_id ||\n  input.response_recipient ||\n  input.recipient ||\n  '331349444'\n);\n\nconst rawPrompt =\n`Short vertical video of a modern analytics interface.\n\nScene:\nA clean digital dashboard appears on screen.\nA progress bar smoothly fills from 0 to 100 percent.\n\nVisual style:\nminimal corporate UI, white background,\nsoft shadows, blue and cyan accents,\nno people, no faces, no personal data.\n\nAnimation:\nsmooth transitions, light zoom-in,\nfocused on the dashboard and progress indicator.\n\nAtmosphere:\nhigh-tech, calm, professional.`;\n\nconst safePrompt = rawPrompt\n  .replace(/candidate/gi, 'profile')\n  .replace(/HR/gi, 'analytics')\n  .replace(/hiring/gi, 'evaluation')\n  .replace(/resume/gi, 'data')\n  .trim();\n\nreturn [{\n  json: {\n    ...input,\n    execution_id: input.execution_id || ($execution.id + '_' + Date.now()),\n    source: input.source || 'video_request',\n    chat_id: chatId,\n\n    candidate_name: input.candidate_name || 'demo_profile',\n    vacancy_title: input.vacancy_title || 'analytics_result',\n    score: input.score ?? 100,\n\n    video_required: true,\n    video_prompt: safePrompt\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -928,
        736
      ],
      "id": "3c36acfd-ac82-4cda-a7f9-25ad65bf75ce",
      "name": "Build video context"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/videos",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n{\n  model: 'sora-2',\n  prompt: $json.video_prompt,\n  seconds: '4',\n  size: '720x1280'\n}\n}}",
        "options": {}
      },
