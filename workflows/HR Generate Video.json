    {
      "parameters": {
        "jsCode": "const videoId = $json.id || $json.video?.id || null;\n\nif (!videoId) {\n  throw new Error('OpenAI video id is missing');\n}\n\nconst ctx = $('Build video context').first().json;\n\nreturn [{\n  json: {\n    ...ctx,\n    video_id: videoId,\n    video_status: $json.status || 'queued',\n    poll_attempt: 1,\n    max_poll_attempts: 20\n  }\n}];"
      },
